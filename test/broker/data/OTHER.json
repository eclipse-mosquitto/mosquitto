				{"type":"send", "payload":"82 r16 m1 s11 'subpub/qos1' 01"},
				{"type":"recv", "payload":"90 r3 m1 01"},
				{"type":"send", "payload":"32 r22 s11 'subpub/qos1' m2 'message'"},
				{"type":"recv", "payload":"32 r22 s11 'subpub/qos1' m1 'message'"},
				{"type":"recv", "payload":"40 r2 m2"}
			]},
			{ "name": "subpub self publish qos2", "expect_disconnect":false, "msgs": [
				{"type":"send", "payload":"82 r16 m1 s11 'subpub/qos2' 02"},
				{"type":"recv", "payload":"90 r3 m1 02"},
				{"type":"send", "payload":"34 r22 s11 'subpub/qos2' m2 'message'"},
				{"type":"recv", "payload":"50 r2 m2"},
				{"type":"send", "payload":"62 r2 m2"},
				{"type":"recv", "payload":"34 r22 s11 'subpub/qos2' m1 'message'"},
				{"type":"recv", "payload":"70 r2 m2"}
			]},
			{ "name": "subpub retain as normal qos0", "expect_disconnect":false, "msgs": [
